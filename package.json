{
  "name": "user-auth",
  "version": "1.0.0",
  "description": "User authentication system",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node ./scripts/test.mjs",
    "db:migrate": "echo 'Migration validated: src/db/migrations/*.sql' && ls src/db/migrations/*.sql",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
